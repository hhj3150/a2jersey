# --- 기본 ---
PORT=4000
DATABASE_PATH=./data/leads.db

# 로컬 개발: 프론트 dev 서버 origin
# 프로덕션(Railway)에서는 Netlify 도메인을 콤마로 추가
# 예: CORS_ORIGINS=https://a2jersey-pre.netlify.app,https://www.a2jerseymilk.com
CORS_ORIGINS=http://localhost:5173

# --- 관리자 페이지 Basic Auth ---
# Railway 배포 시 ADMIN_PASSWORD 는 반드시 강한 값으로 교체하세요.
# (값이 비어있거나 'change-me-in-production' 그대로면 /api/admin/* 가 503 으로 차단됩니다)
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-in-production

# --- (선택) Solapi SMS/LMS 발송 ---
# 3개 모두 채워야 일괄 SMS 발송 가능. 비어있으면 /api/admin/broadcast 가 자동 드라이런.
# https://console.solapi.com → API Key 발급 + 발신번호 등록
# SOLAPI_API_KEY=NCSXXXXXXXXXX
# SOLAPI_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SOLAPI_FROM_NUMBER=01012345678

# --- (선택) 카카오 알림톡 ---
# 솔라피 콘솔에서 카카오 채널 연동 + 템플릿 사전 승인 필요.
# KAKAO_PFID=KA01PFXXXXXXX
# KAKAO_TEMPLATE_ID=KA01TPXXXXXXX

# --- 080 수신거부 번호 ---
# 정통망법 §50: 광고 메시지에는 실수신거부 가능한 번호가 필수.
# 미설정 시 /api/admin/broadcast 가 OPT_OUT_NOT_CONFIGURED 로 실제 발송 차단 (드라이런만 가능).
# Solapi 콘솔 → 080 수신거부 부가서비스 신청 → 발급된 번호 등록.
# OPT_OUT_NUMBER=080-1234-5678

# --- (선택) 강제 드라이런 ---
# true 로 두면 /api/admin/broadcast 호출이 항상 시뮬레이션 (실제 발송 X).
# 운영 전 점검 시 권장.
# BROADCAST_DRY_RUN=true

# --- (선택) GitHub Actions cron 백업 ---
# 설정 시 /api/admin/backup 을 'Authorization: Bearer <token>' 으로도 호출 가능.
# 비밀번호와 분리되어 자동화 노출 위험을 줄임. 32자 이상 랜덤 권장.
# BACKUP_TOKEN=replace-with-32-byte-random-string
